{
  "name": "forge",
  "version": "0.1.0",
  "description": "Personal coding agent with multi-provider support",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "forge": "./src/index.ts"
  },
  "scripts": {
    "dev":            "bun --hot ./src/index.ts",
    "build":          "bun build --target=bun --compile ./src/index.ts --outfile=./dist/forge",
    "install:local":  "bun link",
    "install:global": "bun build --target=bun --compile ./src/index.ts --outfile /usr/local/bin/forge",
    "test":           "bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "openai": "latest",
    "commander": "^15.0.0",
    "ink": "^7.0.6",
    "react": "^19.2.7",
    "chalk": "^5.6.2",
    "ora": "^9.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "typescript": "^5.9.3"
  },
  "private": true
}
